# Environment Variables
# Copy this file to .env.local and fill in your values

# Google Gemini API Key for LLM features (panic mode, weekly summary)
# Get your free API key at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# MongoDB Connection String
MONGODB_URI=mongodb://localhost:27017/compulsecare
# or use MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/compulsecare

# JWT Secret for Custom Authentication (min 32 characters)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars

# Supabase Configuration (for document storage)
# Get your credentials at: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Optional: Firebase Configuration
# FIREBASE_API_KEY=
# FIREBASE_AUTH_DOMAIN=
# FIREBASE_PROJECT_ID=
