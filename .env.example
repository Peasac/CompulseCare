# Environment Variables
# Copy this file to .env.local and fill in your values

# Google Gemini API Key for LLM features (panic mode, weekly summary)
# Get your free API key at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Database URL (MongoDB, PostgreSQL, etc.)
DATABASE_URL=mongodb://localhost:27017/compulsecare
# or: postgresql://user:password@localhost:5432/compulsecare

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32

# Optional: Firebase Configuration
# FIREBASE_API_KEY=
# FIREBASE_AUTH_DOMAIN=
# FIREBASE_PROJECT_ID=
